<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Form View للـ Wizard -->
    <record id="view_kpi_purchase_wizard_form" model="ir.ui.view">
        <field name="name">kpi.purchase.wizard.form</field>
        <field name="model">kpi.purchase.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Purchase Orders">
                <group>
                    <field name="project_id" readonly="1"/>
                </group>
                <p class="alert alert-info" role="alert">
                    Select the equipment you want to purchase and click "Create Orders".
                </p>
                <field name="line_ids">
                    <tree editable="bottom">
                        <field name="select"/>
                        <field name="equipment_id"/>
                        <field name="vendor_id"/>
                        <field name="estimated_cost" widget="monetary"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_create_purchase_orders"
                            type="object"
                            string="Create Purchase Orders"
                            class="oe_highlight"/>
                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action لفتح الـ Wizard -->
    <record id="action_kpi_purchase_wizard" model="ir.actions.act_window">
        <field name="name">Create Purchase Orders</field>
        <field name="res_model">kpi.purchase.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_kpi_project"/>
        <field name="binding_type">action</field>
    </record>
</odoo>