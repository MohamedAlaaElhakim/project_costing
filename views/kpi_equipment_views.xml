<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ========================= -->
    <!-- KPI Equipment Tree View -->
    <!-- ========================= -->
    <record id="view_kpi_equipment_tree" model="ir.ui.view">
        <field name="name">kpi.equipment.tree</field>
        <field name="model">kpi.equipment</field>
        <field name="arch" type="xml">
            <tree string="Equipment Lines"
                  decoration-danger="is_over_allocated == True"
                  default_order="create_date desc">
                <field name="project_id" optional="show"/>
                <field name="equipment_id" optional="show"/>
                <field name="quantity" optional="show"/>
                <field name="days"/>
                <field name="day_cost" widget="monetary" optional="show"/>
                <field name="subtotal" widget="monetary" sum="Total Equipment Cost"/>
                <field name="utilization_percent" widget="progressbar" optional="hide"/>
                <field name="is_over_allocated" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- ========================= -->
    <!-- KPI Equipment Kanban View (جديد) -->
    <!-- ========================= -->
    <record id="view_kpi_equipment_kanban" model="ir.ui.view">
        <field name="name">kpi.equipment.kanban</field>
        <field name="model">kpi.equipment</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="equipment_id"/>
                <field name="project_id"/>
                <field name="days"/>
                <field name="subtotal"/>
                <field name="is_over_allocated"/>
                <field name="utilization_percent"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="equipment_id"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <strong>Project:</strong>
                                    <field name="project_id"/>
                                </div>
                                <div>
                                    <strong>Days:</strong>
                                    <field name="days"/>
                                </div>
                                <div>
                                    <strong>Cost:</strong>
                                    <field name="subtotal" widget="monetary"/>
                                </div>
                                <div t-if="is_over_allocated" class="text-danger">
                                    <strong>⚠️ Over Allocated!</strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="utilization_percent" widget="progressbar"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========================= -->
    <!-- KPI Equipment Form View -->
    <!-- ========================= -->
    <record id="view_kpi_equipment_form" model="ir.ui.view">
        <field name="name">kpi.equipment.form</field>
        <field name="model">kpi.equipment</field>
        <field name="arch" type="xml">
            <form string="Equipment Line">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="project_id" />
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="equipment_id"/>
                            <field name="project_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="quantity"/>
                            <field name="days"/>
                            <field name="day_cost" widget="monetary"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Time &amp; Cost">
                            <group>
                                <group>
                                    <field name="hours" readonly="1"/>
                                    <field name="hour_cost" widget="monetary" readonly="1"/>
                                    <field name="subtotal" widget="monetary" readonly="1"/>
                                </group>
                                <group>
                                    <field name="planned_days" readonly="1"/>
                                    <field name="cost_share_percent" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="KPIs">
                            <group>
                                <group string="Utilization">
                                    <field name="utilization_percent" widget="progressbar" readonly="1"/>
                                    <field name="is_over_allocated" readonly="1" widget="boolean_toggle"/>
                                </group>
                                <group string="Cost Analysis">
                                    <field name="cost_share_percent" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- KPI Equipment Search View -->
    <!-- ========================= -->
    <record id="view_kpi_equipment_search" model="ir.ui.view">
        <field name="name">kpi.equipment.search</field>
        <field name="model">kpi.equipment</field>
        <field name="arch" type="xml">
            <search string="Equipment Lines">
                <field name="project_id"/>
                <field name="equipment_id"/>

                <filter string="Over Allocated"
                        name="over_allocated"
                        domain="[('is_over_allocated', '=', True)]"/>

                <filter string="High Utilization (>80%)"
                        name="high_utilization"
                        domain="[('utilization_percent', '>', 80)]"/>

                <separator/>

                <filter string="High Cost"
                        name="high_cost"
                        domain="[('subtotal', '>', 1000)]"/>

                <separator/>

                <filter string="By Project"
                        name="group_project"
                        context="{'group_by': 'project_id'}"/>

                <filter string="By Equipment"
                        name="group_equipment"
                        context="{'group_by': 'equipment_id'}"/>

                <filter string="By Month"
                        name="group_month"
                        context="{'group_by': 'create_date:month'}"/>
            </search>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Pivot View -->
    <!-- ========================= -->
    <record id="view_kpi_equipment_pivot" model="ir.ui.view">
        <field name="name">kpi.equipment.pivot</field>
        <field name="model">kpi.equipment</field>
        <field name="arch" type="xml">
            <pivot string="Equipment Analysis">
                <field name="project_id" type="row"/>
                <field name="equipment_id" type="row"/>
                <field name="days" type="measure"/>
                <field name="subtotal" type="measure"/>
                <field name="utilization_percent" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Graph View -->
    <!-- ========================= -->
    <record id="view_kpi_equipment_graph" model="ir.ui.view">
        <field name="name">kpi.equipment.graph</field>
        <field name="model">kpi.equipment</field>
        <field name="arch" type="xml">
            <graph string="Equipment Distribution" type="bar">
                <field name="equipment_id" type="row"/>
                <field name="days" type="measure"/>
                <field name="subtotal" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Action -->
    <!-- ========================= -->
    <record id="action_kpi_equipment" model="ir.actions.act_window">
        <field name="name">KPI Equipment Lines</field>
        <field name="res_model">kpi.equipment</field>
        <field name="view_mode">tree,kanban,form,pivot,graph</field>
        <field name="search_view_id" ref="view_kpi_equipment_search"/>
        <field name="context">{'search_default_group_project': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Equipment Line!
            </p>
            <p>
                Track equipment usage, costs, and utilization across projects.
            </p>
        </field>
    </record>

</odoo>