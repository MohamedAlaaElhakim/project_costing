<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ========================= -->
    <!-- Tree View - مع Decorations -->
    <!-- ========================= -->
    <record id="view_kpi_project_tree" model="ir.ui.view">
        <field name="name">kpi.project.tree</field>
        <field name="model">kpi.project</field>
        <field name="arch" type="xml">
            <tree string="Project KPIs"
                  decoration-danger="is_over_budget == True"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'submitted'"
                  decoration-muted="state == 'cancelled'"
                  default_order="create_date desc">
                <field name="code"/>
                <field name="name"/>
                <field name="client_id"/>
                <field name="budget" widget="monetary"/>
                <field name="selling_price" widget="monetary"/>
                <field name="total_cost" widget="monetary"/>
                <field name="profit" widget="monetary"
                       decoration-danger="profit &lt; 0"/>
                <field name="profit_margin"/>
                <field name="remaining_budget" widget="monetary"/>
                <field name="is_over_budget"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Kanban View - إضافة جديدة -->
    <!-- ========================= -->
    <record id="view_kpi_project_kanban" model="ir.ui.view">
        <field name="name">kpi.project.kanban</field>
        <field name="model">kpi.project</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="name"/>
                <field name="code"/>
                <field name="client_id"/>
                <field name="state"/>
                <field name="budget"/>
                <field name="total_cost"/>
                <field name="is_over_budget"/>
                <field name="profit_margin"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="state" widget="label_selection"
                                       options="{'classes': {'draft': 'default', 'submitted': 'warning', 'approved': 'info', 'done': 'success', 'cancelled': 'danger'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div class="o_kanban_tags_section">
                                    <field name="client_id"/>
                                </div>
                                <div>
                                    <strong>Budget:</strong>
                                    <field name="budget" widget="monetary"/>
                                </div>
                                <div>
                                    <strong>Cost:</strong>
                                    <field name="total_cost" widget="monetary"/>
                                </div>
                                <div t-if="is_over_budget" class="text-danger">
                                    <strong>⚠️ Over Budget!</strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="profit_margin" widget="progressbar"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Form View - مع Smart Buttons -->
    <!-- ========================= -->
    <record id="view_kpi_project_form" model="ir.ui.view">
        <field name="name">kpi.project.form</field>
        <field name="model">kpi.project</field>
        <field name="arch" type="xml">
            <form string="Project KPIs">
                <header>
                    <button name="action_submit"
                            type="object"
                            string="Submit"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_approve"
                            type="object"
                            string="Approve"
                            class="oe_highlight"
                            invisible="state != 'submitted'"/>
                    <button name="action_done"
                            type="object"
                            string="Mark as Done"
                            class="oe_highlight"
                            invisible="state != 'approved'"/>
                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            invisible="state not in ('draft', 'submitted', 'approved')"/>
                    <button name="action_reset_to_draft"
                            type="object"
                            string="Reopen"
                            confirm="Are you sure? This will reset the project to draft state."
                            invisible="state not in ('done', 'cancelled')"
                            groups="project_costing.group_kpi_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,done"/>

                    <button name="%(project_costing.action_report_kpi_project)d"
                            type="action"
                            string="Print Report"
                            class="oe_print_button"
                            icon="fa-file-pdf-o"/>

                    <button name="action_open_purchase_wizard"
                            type="object"
                            string="Create Purchase Orders"
                            class="btn-secondary"
                            icon="fa-shopping-cart"
                            invisible="state != 'draft'"/>
                </header>

                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="%(project_costing.action_kpi_labor)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-users">
                            <field name="labor_lines_count" widget="statinfo" string="Labor Lines"/>
                        </button>
                        <button name="%(project_costing.action_kpi_equipment)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-cogs">
                            <field name="equipment_lines_count" widget="statinfo" string="Equipment Lines"/>
                        </button>
                    </div>

                    <!-- Avatar/Icon -->
                    <div class="oe_title">
                        <h1>
                            <field name="code" readonly="1"/>
                        </h1>
                        <field name="name"
                               placeholder="Project Name..."
                               readonly="state in ('done', 'cancelled')"/>
                    </div>

                    <group>
                        <group>
                            <field name="client_id"
                                   readonly="state in ('done', 'cancelled')"/>
                            <field name="project_id"
                                   readonly="state in ('done', 'cancelled')"
                                   groups="base.group_user"/>
                            <field name="start_date"
                                   readonly="state in ('done', 'cancelled')"/>
                            <field name="end_date"
                                   readonly="state in ('done', 'cancelled')"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="budget" widget="monetary"
                                   readonly="state in ('done', 'cancelled')"/>
                            <field name="selling_price" widget="monetary"
                                   readonly="state in ('done', 'cancelled')"/>
                            <field name="total_cost" widget="monetary" readonly="1"/>
                            <field name="profit" widget="monetary" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Labor Lines">
                            <field name="labor_ids"
                                   readonly="state in ('done', 'cancelled')">
                                <tree editable="bottom" default_order="id">
                                    <field name="employee_id"/>
                                    <field name="hours"/>
                                    <field name="hour_cost"/>
                                    <field name="subtotal" sum="Total Labor"/>
                                    <field name="is_overtime"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="employee_id"
                                               readonly="parent.state in ('done', 'cancelled')"/>
                                        <field name="hours"
                                               readonly="parent.state in ('done', 'cancelled')"/>
                                        <field name="hour_cost"
                                               readonly="parent.state in ('done', 'cancelled')"/>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <page string="Equipment Lines">
                            <field name="equipment_ids"
                                   readonly="state in ('done', 'cancelled')">
                                <tree editable="bottom" default_order="id">
                                    <field name="equipment_id"/>
                                    <field name="quantity"/>
                                    <field name="days"/>
                                    <field name="day_cost"/>
                                    <field name="subtotal" sum="Total Equipment"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="equipment_id"
                                               readonly="parent.state in ('done', 'cancelled')"/>
                                        <field name="quantity"
                                               readonly="parent.state in ('done', 'cancelled')"/>
                                        <field name="days"
                                               readonly="parent.state in ('done', 'cancelled')"/>
                                        <field name="day_cost"
                                               readonly="parent.state in ('done', 'cancelled')"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Search View - محسّن -->
    <!-- ========================= -->
    <record id="view_kpi_project_search" model="ir.ui.view">
        <field name="name">kpi.project.search</field>
        <field name="model">kpi.project</field>
        <field name="arch" type="xml">
            <search string="Project KPIs">
                <field name="code"/>
                <field name="name"/>
                <field name="client_id"/>
                <field name="state"/>

                <!-- Filters -->
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="submitted" string="Submitted" domain="[('state','=','submitted')]"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                <filter name="done" string="Done" domain="[('state','=','done')]"/>
                <filter name="cancelled" string="Cancelled" domain="[('state','=','cancelled')]"/>

                <separator/>

                <filter name="over_budget" string="Over Budget"
                        domain="[('is_over_budget', '=', True)]"/>
                <filter name="profitable" string="Profitable"
                        domain="[('profit', '>', 0)]"/>
                <filter name="my_projects" string="My Projects"
                        domain="[('create_uid', '=', uid)]"/>

                <separator/>

                <!-- Group By -->
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_client" string="Client" context="{'group_by': 'client_id'}"/>
                    <filter name="group_create_date" string="Created Date"
                            context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Graph & Pivot Views - للـ Reporting -->
    <!-- ========================= -->
    <record id="view_kpi_project_graph" model="ir.ui.view">
        <field name="name">kpi.project.graph</field>
        <field name="model">kpi.project</field>
        <field name="arch" type="xml">
            <graph string="Project KPIs Analysis" type="bar">
                <field name="name"/>
                <field name="profit" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_kpi_project_pivot" model="ir.ui.view">
        <field name="name">kpi.project.pivot</field>
        <field name="model">kpi.project</field>
        <field name="arch" type="xml">
            <pivot string="Project KPIs Analysis">
                <field name="state" type="row"/>
                <field name="client_id" type="col"/>
                <field name="profit" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Action - محدّث -->
    <!-- ========================= -->
    <record id="action_kpi_project" model="ir.actions.act_window">
        <field name="name">Project KPIs</field>
        <field name="res_model">kpi.project</field>
        <field name="view_mode">tree,kanban,form,graph,pivot</field>
        <field name="search_view_id" ref="view_kpi_project_search"/>
        <field name="context">{'search_default_group_state': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first KPI Project!
            </p>
            <p>
                Track project costs, labor, equipment, and profitability.
            </p>
        </field>
    </record>


</odoo>