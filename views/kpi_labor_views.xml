<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ========================= -->
    <!-- KPI Labor Tree View -->
    <!-- ========================= -->
    <record id="view_kpi_labor_tree" model="ir.ui.view">
        <field name="name">kpi.labor.tree</field>
        <field name="model">kpi.labor</field>
        <field name="arch" type="xml">
            <tree string="Labor Lines"
                  decoration-danger="is_over_allocated == True"
                  decoration-warning="is_overtime == True"
                  default_order="create_date desc">
                <field name="project_id" optional="show"/>
                <field name="employee_id" optional="show"/>
                <field name="hours"/>
                <field name="days" optional="hide"/>
                <field name="hour_cost" widget="monetary" optional="show"/>
                <field name="subtotal" widget="monetary" sum="Total Labor Cost"/>
                <field name="overtime_hours" optional="hide"/>
                <field name="utilization_percent" widget="progressbar" optional="hide"/>
                <field name="cost_share_percent" optional="hide"/>
                <field name="is_overtime" column_invisible="True"/>
                <field name="is_over_allocated" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- ========================= -->
    <!-- KPI Labor Kanban View  -->
    <!-- ========================= -->
    <record id="view_kpi_labor_kanban" model="ir.ui.view">
        <field name="name">kpi.labor.kanban</field>
        <field name="model">kpi.labor</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="employee_id"/>
                <field name="project_id"/>
                <field name="hours"/>
                <field name="subtotal"/>
                <field name="is_overtime"/>
                <field name="is_over_allocated"/>
                <field name="utilization_percent"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="employee_id"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <strong>Project:</strong>
                                    <field name="project_id"/>
                                </div>
                                <div>
                                    <strong>Hours:</strong>
                                    <field name="hours"/>
                                </div>
                                <div>
                                    <strong>Cost:</strong>
                                    <field name="subtotal" widget="monetary"/>
                                </div>
                                <div t-if="is_overtime" class="text-warning">
                                    <strong>⚠️ Overtime:</strong>
                                    <field name="overtime_hours"/>h
                                </div>
                                <div t-if="is_over_allocated" class="text-danger">
                                    <strong>⚠️ Over Allocated!</strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="utilization_percent" widget="progressbar"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ========================= -->
    <!-- KPI Labor Form View -->
    <!-- ========================= -->
    <record id="view_kpi_labor_form" model="ir.ui.view">
        <field name="name">kpi.labor.form</field>
        <field name="model">kpi.labor</field>
        <field name="arch" type="xml">
            <form string="Labor Line">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="project_id"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="project_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="currency_id" invisible="1"/>
                            <field name="hours"/>
                            <field name="hour_cost" widget="monetary"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Time &amp; Cost">
                            <group>
                                <group>
                                    <field name="days" readonly="1"/>
                                    <field name="subtotal" widget="monetary" readonly="1"/>
                                </group>
                                <group>
                                    <field name="overtime_hours" readonly="1"/>
                                    <field name="is_overtime" readonly="1" widget="boolean_toggle"/>
                                </group>
                            </group>
                        </page>

                        <page string="KPIs">
                            <group>
                                <group string="Planned">
                                    <field name="planned_days" readonly="1"/>
                                    <field name="planned_hours" readonly="1"/>
                                </group>
                                <group string="Utilization">
                                    <field name="utilization_percent" widget="progressbar" readonly="1"/>
                                    <field name="is_over_allocated" readonly="1" widget="boolean_toggle"/>
                                </group>
                                <group string="Cost Analysis">
                                    <field name="cost_share_percent" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================= -->
    <!-- KPI Labor Search View -->
    <!-- ========================= -->
    <record id="view_kpi_labor_search" model="ir.ui.view">
        <field name="name">kpi.labor.search</field>
        <field name="model">kpi.labor</field>
        <field name="arch" type="xml">
            <search string="Labor Lines">
                <field name="project_id"/>
                <field name="employee_id"/>

                <filter string="Over Allocated"
                        name="over_allocated"
                        domain="[('is_over_allocated', '=', True)]"/>

                <filter string="Overtime"
                        name="overtime"
                        domain="[('is_overtime', '=', True)]"/>

                <separator/>

                <filter string="High Cost"
                        name="high_cost"
                        domain="[('subtotal', '>', 1000)]"/>

                <separator/>

                <filter string="By Project"
                        name="group_project"
                        context="{'group_by': 'project_id'}"/>

                <filter string="By Employee"
                        name="group_employee"
                        context="{'group_by': 'employee_id'}"/>

                <filter string="By Month"
                        name="group_month"
                        context="{'group_by': 'create_date:month'}"/>
            </search>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Pivot View -->
    <!-- ========================= -->
    <record id="view_kpi_labor_pivot" model="ir.ui.view">
        <field name="name">kpi.labor.pivot</field>
        <field name="model">kpi.labor</field>
        <field name="arch" type="xml">
            <pivot string="Labor Analysis">
                <field name="project_id" type="row"/>
                <field name="employee_id" type="row"/>
                <field name="hours" type="measure"/>
                <field name="subtotal" type="measure"/>
                <field name="utilization_percent" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Graph View -->
    <!-- ========================= -->
    <record id="view_kpi_labor_graph" model="ir.ui.view">
        <field name="name">kpi.labor.graph</field>
        <field name="model">kpi.labor</field>
        <field name="arch" type="xml">
            <graph string="Labor Distribution" type="bar">
                <field name="employee_id" type="row"/>
                <field name="hours" type="measure"/>
                <field name="subtotal" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Action -->
    <!-- ========================= -->
    <record id="action_kpi_labor" model="ir.actions.act_window">
        <field name="name">KPI Labor Lines</field>
        <field name="res_model">kpi.labor</field>
        <field name="view_mode">tree,kanban,form,pivot,graph</field>
        <field name="search_view_id" ref="view_kpi_labor_search"/>
        <field name="context">{'search_default_group_project': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Labor Line!
            </p>
            <p>
                Track labor hours, costs, and utilization across projects.
            </p>
        </field>
    </record>

</odoo>