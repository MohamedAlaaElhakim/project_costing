<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Category -->
    <record id="module_category_kpi_management" model="ir.module.category">
        <field name="name">KPI Management</field>
        <field name="description">KPI Project Management System</field>
        <field name="sequence">50</field>
    </record>

    <!-- User Group - External ID: project_costing.group_kpi_user -->
    <record id="group_kpi_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_kpi_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Manager Group - External ID: project_costing.group_kpi_manager -->
    <record id="group_kpi_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_kpi_management"/>
        <field name="implied_ids" eval="[(4, ref('group_kpi_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>